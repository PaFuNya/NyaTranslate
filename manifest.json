{
  "manifest_version": 3,
  "name": "NyaTranslate-喵译",
  "version": "3.1.0",
  "description": "划选网页文字，通过任意 OpenAI 兼容或 Anthropic 模型即时获取翻译和专业术语解释；支持截图/图片视觉翻译。",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_title": "NyaTranslate-喵译"
  },
  "permissions": [
    "storage",
    "contextMenus",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "commands": {
    "nya-screenshot": {
      "suggested_key": {
        "default": "Alt+Shift+S",
        "mac": "MacCtrl+Shift+S"
      },
      "description": "NyaTranslate 区域截图翻译"
    }
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "appearance.js",
        "material-select.js",
        "content.js"
      ],
      "css": [
        "theme.css",
        "style.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
